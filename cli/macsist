#!/usr/bin/env bash
# macsist — ops CLI for the Macsist menu-bar app + LLM server (M10, SPEC §5.6).
#
#   macsist                    ensure agents are running; status summary
#   macsist start|stop|restart [app|server]
#   macsist status             agents, health, provider/models, TCC
#   macsist logs [app|server] [-f]
#   macsist settings|history   open the main window (distributed notification)
#   macsist tasks              show the Hermes kanban board (read-only, M13)
#   macsist doctor             full diagnosis (✓/✗ per check)
#   macsist update             git pull + redeploy
#
# Installed as a symlink (install.sh): /usr/local/bin/macsist → <repo>/cli/macsist
# so `update` finds the repo by resolving its own link.

set -u

SELF="${BASH_SOURCE[0]}"
while [[ -L "$SELF" ]]; do
    target="$(readlink "$SELF")"
    [[ "$target" == /* ]] || target="$(cd "$(dirname "$SELF")" && pwd)/$target"
    SELF="$target"
done
REPO_ROOT="$(cd "$(dirname "$SELF")/.." && pwd)"

APP_LABEL=com.macsist.app
SERVER_LABEL=com.macsist.llm-server
DOMAIN="gui/$(id -u)"
SUPPORT_DIR="$HOME/Library/Application Support/Macsist"
APP_BUNDLE="$SUPPORT_DIR/Macsist.app"          # M12: signed py2app bundle
APP_EXE="$APP_BUNDLE/Contents/MacOS/Macsist"
NOTIFY_BIN="$APP_BUNDLE/Contents/MacOS/macsist_notify"
SERVER_DIR="$SUPPORT_DIR/server"
CONFIG_JSON="$SUPPORT_DIR/config.json"
APP_PLIST="$HOME/Library/LaunchAgents/$APP_LABEL.plist"
SERVER_PLIST="$HOME/Library/LaunchAgents/$SERVER_LABEL.plist"
APP_LOG="$HOME/Library/Logs/Macsist/app.log"
SERVER_LOG_DIR="$HOME/Library/Logs/llm-server"
CONDA_BASE=/opt/homebrew/Caskroom/miniforge/base
CONFIGURE="$REPO_ROOT/cli/configure.py"

C_OK=$'\033[32m✓\033[0m'; C_BAD=$'\033[31m✗\033[0m'; C_WARN=$'\033[33m△\033[0m'

pybin() {  # configure.py runner (stdlib-only) — bundle interpreter first (M12)
    if [[ -x "$APP_BUNDLE/Contents/MacOS/python" ]]; then echo "$APP_BUNDLE/Contents/MacOS/python"
    elif [[ -x "$CONDA_BASE/bin/python3" ]]; then echo "$CONDA_BASE/bin/python3"
    else command -v python3; fi
}

agent_loaded() { launchctl print "$DOMAIN/$1" >/dev/null 2>&1; }
agent_pid() {
    launchctl print "$DOMAIN/$1" 2>/dev/null \
        | awk '/^[[:space:]]*pid = /{print $3; exit}'
}

load_cfg() {  # sets CFG_OK, P_*, HK_* (defaults if config helper fails)
    CFG_OK=0 P_NAME="" P_BASE_URL="" P_IS_LOCAL=0 P_EXPLAIN="" P_VISION=""
    P_KEY_ACCOUNT="" P_KEY_PRESENT="" HK_TEXT="" HK_REGION="" HK_HISTORY=""
    local out
    if out="$("$(pybin)" "$CONFIGURE" status --shell 2>/dev/null)"; then
        eval "$out"
    fi
}

label_for() { [[ "$1" == app ]] && echo "$APP_LABEL" || echo "$SERVER_LABEL"; }
plist_for() { [[ "$1" == app ]] && echo "$APP_PLIST" || echo "$SERVER_PLIST"; }

targets() {  # start/stop/restart arg → list of targets
    case "${1:-}" in
        app) echo app ;;
        server) echo server ;;
        "") echo "app server" ;;
        *) echo "알 수 없는 대상: $1 (app|server)" >&2; return 2 ;;
    esac
}

cmd_start() {
    local t; for t in $(targets "${1:-}") ; do
        local label plist; label=$(label_for "$t"); plist=$(plist_for "$t")
        if [[ ! -f "$plist" ]]; then
            echo "· $t: 설치되지 않음 ($plist 없음) — 건너뜀"
        elif agent_loaded "$label"; then
            echo "· $t: 이미 실행 중 (PID $(agent_pid "$label"))"
        else
            launchctl bootstrap "$DOMAIN" "$plist" && echo "· $t: 시작됨"
        fi
    done
}

cmd_stop() {
    local t; for t in $(targets "${1:-}") ; do
        local label; label=$(label_for "$t")
        if agent_loaded "$label"; then
            launchctl bootout "$DOMAIN/$label" && echo "· $t: 정지됨"
        else
            echo "· $t: 실행 중이 아님"
        fi
    done
}

cmd_restart() {
    local t; for t in $(targets "${1:-}") ; do
        local label plist; label=$(label_for "$t"); plist=$(plist_for "$t")
        if agent_loaded "$label"; then
            launchctl kickstart -k "$DOMAIN/$label" && echo "· $t: 재시작됨"
        elif [[ -f "$plist" ]]; then
            launchctl bootstrap "$DOMAIN" "$plist" && echo "· $t: 시작됨 (정지 상태였음)"
        else
            echo "· $t: 설치되지 않음 — 건너뜀"
        fi
    done
}

health_local() {  # prints a one-line local server health summary
    local body
    body="$(curl -s --max-time 3 http://127.0.0.1:8000/health)" || true
    if [[ -z "$body" ]]; then echo "접속 불가 (서버 다운?)"; return 1; fi
    echo "$body" | sed -e 's/[{}"]//g' -e 's/,/ /g' -e 's/backends://'
    [[ "$body" == *'"status":"ok"'* ]]
}

cmd_status() {
    load_cfg
    echo "── Macsist 상태 ──"
    local label pid
    for t in app server; do
        label=$(label_for "$t")
        if [[ ! -f "$(plist_for "$t")" ]]; then
            if [[ "$t" == server && "$P_IS_LOCAL" == 0 ]]; then
                echo "· server 에이전트: 없음 (외부 API 사용 설정)"
            else
                echo "· $t 에이전트: 설치되지 않음"
            fi
        elif agent_loaded "$label"; then
            pid=$(agent_pid "$label")
            echo "· $t 에이전트: 실행 중 (PID ${pid:--})"
        else
            echo "· $t 에이전트: 정지됨 (macsist start $t)"
        fi
    done
    if [[ "$CFG_OK" == 1 ]]; then
        echo "· 프로바이더: $P_NAME ($P_BASE_URL)"
        echo "  모델: explain=$P_EXPLAIN / vision=$P_VISION"
        if [[ "$P_IS_LOCAL" == 1 ]]; then
            echo "· 서버 상태: $(health_local || true)"
        else
            echo "· 프로바이더 상태: $("$(pybin)" "$CONFIGURE" probe 2>/dev/null \
                | tr -d '\n ' | sed 's/[{}"]//g')"
        fi
    else
        echo "· 설정: config.json 읽기 실패"
    fi
    local tcc
    tcc="$(grep "^TCC: " "$APP_LOG" 2>/dev/null | tail -1)"
    echo "· ${tcc:-TCC: 기록 없음 (macsist restart app 후 재확인)}"
}

cmd_logs() {
    local target="" follow=""
    local arg; for arg in "$@"; do
        case "$arg" in
            -f) follow="-f" ;;
            app|server) target="$arg" ;;
            *) echo "사용법: macsist logs [app|server] [-f]" >&2; return 2 ;;
        esac
    done
    case "$target" in
        app)    tail $follow -n 50 "$APP_LOG" ;;
        server) tail $follow -n 30 "$SERVER_LOG_DIR"/{launchd,proxy,vlm,lm}.log ;;
        *)      tail $follow -n 30 "$APP_LOG" "$SERVER_LOG_DIR/proxy.log" ;;
    esac
}

post_notification() {
    # M12: the bundle's second launcher (py2app extra_scripts) has PyObjC.
    if [[ ! -x "$NOTIFY_BIN" ]]; then
        echo "앱이 설치되지 않았습니다 — 먼저 install.sh 를 실행하세요." >&2
        return 1
    fi
    agent_loaded "$APP_LABEL" || echo "(앱이 실행 중이 아닙니다 — macsist start app)" >&2
    "$NOTIFY_BIN" "$1"
}

cmd_tasks() {  # M13: read-only Hermes kanban board + focus the 작업 tab if running
    "$(pybin)" "$CONFIGURE" tasks || echo "작업을 읽을 수 없습니다 (Hermes kanban 없음)"
    if [[ -x "$NOTIFY_BIN" ]] && agent_loaded "$APP_LABEL"; then
        "$NOTIFY_BIN" "com.macsist.assistant.showTasks" >/dev/null 2>&1 || true
    fi
}

cmd_doctor() {
    load_cfg
    local fails=0
    check() {  # check <섹션에 영향: 1|0> <조건 rc> <설명> [실패 힌트]
        local hard="$1" rc="$2" desc="$3" hint="${4:-}"
        if [[ "$rc" == 0 ]]; then echo "  $C_OK $desc"
        else
            echo "  $C_BAD $desc${hint:+ — $hint}"
            [[ "$hard" == 1 ]] && fails=$((fails + 1))
        fi
    }

    echo "[시스템]"
    [[ "$(uname -m)" == arm64 ]]; check 0 $? "Apple Silicon (arm64)"
    local ram_gb disk_gb
    ram_gb=$(($(sysctl -n hw.memsize) / 1073741824))
    disk_gb=$(df -g / | awk 'NR==2{print $4}')
    echo "  · RAM ${ram_gb}GB / 디스크 여유 ${disk_gb}GB"
    if [[ "$P_IS_LOCAL" == 1 ]]; then
        [[ -x "$CONDA_BASE/bin/python3" ]]
        check 1 $? "miniforge ($CONDA_BASE)" "install.sh 를 실행하세요"
    fi

    echo "[배포]"
    [[ -x "$APP_EXE" ]]
    check 1 $? "앱 번들 ($APP_BUNDLE)" "app/deploy.sh"
    codesign --verify --deep --strict "$APP_BUNDLE" 2>/dev/null
    check 1 $? "앱 서명 유효" "app/deploy.sh 재실행"
    [[ -f "$APP_PLIST" ]]; check 1 $? "앱 LaunchAgent plist"
    agent_loaded "$APP_LABEL"; check 1 $? "앱 에이전트 실행 중" "macsist start app"
    if [[ "$P_IS_LOCAL" == 1 ]]; then
        [[ -f "$SERVER_DIR/start_server.sh" ]]
        check 1 $? "서버 배포 ($SERVER_DIR)" "server/deploy.sh"
        [[ -f "$SERVER_PLIST" ]]; check 1 $? "서버 LaunchAgent plist"
        agent_loaded "$SERVER_LABEL"; check 1 $? "서버 에이전트 실행 중" "macsist start server"
        if [[ -f "$SERVER_DIR/models.env" ]]; then
            echo "  · models.env: $(grep -v '^#' "$SERVER_DIR/models.env" | tr '\n' ' ')"
        else
            echo "  · models.env 없음 — 기본 모델 사용"
        fi
    else
        echo "  · 서버: 외부 API 설정 — 로컬 서버 점검 생략"
    fi

    echo "[설정]"
    [[ "$CFG_OK" == 1 ]]; check 1 $? "config.json 유효" "파일 손상 — 백업 후 install.sh 재실행"
    if [[ "$CFG_OK" == 1 ]]; then
        echo "  · 프로바이더: $P_NAME / explain=$P_EXPLAIN / vision=$P_VISION"
        if [[ -n "$P_KEY_ACCOUNT" ]]; then
            [[ "$P_KEY_PRESENT" == 1 ]]
            check 1 $? "API 키 (Keychain: $P_KEY_ACCOUNT)" "install.sh 에서 키 재입력"
        fi
    fi

    echo "[서버]"
    if [[ "$P_IS_LOCAL" == 1 ]]; then
        local h; h="$(health_local)"; check 1 $? "로컬 서버 /health: $h" "macsist logs server"
    else
        "$(pybin)" "$CONFIGURE" probe >/dev/null 2>&1
        check 1 $? "외부 프로바이더 ($P_NAME) 응답" "macsist logs app / 키 확인"
    fi

    echo "[TCC 권한]"
    local tcc
    tcc="$(grep "^TCC: " "$APP_LOG" 2>/dev/null | tail -1)"
    if [[ -z "$tcc" ]]; then
        echo "  $C_WARN 기록 없음 — macsist restart app 후 재확인"
    else
        [[ "$tcc" == *"accessibility=True"* ]]
        check 0 $? "손쉬운 사용 (accessibility)" "시스템 설정 > 개인정보 보호 > 손쉬운 사용"
        if [[ "$tcc" == *"screen_recording=True"* ]]; then
            echo "  $C_OK 화면 기록 (screen_recording)"
        else
            echo "  $C_WARN 화면 기록 미허용 — 영역 캡처(⌘⇧R류)만 영향, 텍스트 설명은 동작"
        fi
    fi

    if [[ "$P_IS_LOCAL" == 1 && "$CFG_OK" == 1 ]]; then
        echo "[모델 캐시]"
        local m dir
        for m in "$P_EXPLAIN" "$P_VISION"; do
            dir="$HOME/.cache/huggingface/hub/models--${m//\//--}"
            [[ -d "$dir" ]]; check 0 $? "HF 캐시: $m" "server/download_models.sh $m"
        done
        [[ -x "$CONDA_BASE/envs/llm-server/bin/python" ]]
        check 0 $? "conda env llm-server" "install.sh 를 실행하세요"
    fi

    echo "[Hermes 연동]"
    local HERMES_BIN="$HOME/.local/bin/hermes"
    local KANBAN_DB="$HOME/.hermes/kanban.db"
    local GW_STATE="$HOME/.hermes/gateway_state.json"
    [[ -x "$HERMES_BIN" ]]
    check 0 $? "hermes CLI ($HERMES_BIN)" "비서는 Hermes 없이도 로컬 전용으로 동작"
    [[ -f "$KANBAN_DB" ]]; check 0 $? "kanban 보드 ($KANBAN_DB)"
    if [[ -f "$GW_STATE" ]]; then
        local gw; gw="$(sed -n 's/.*"gateway_state":"\([^"]*\)".*/\1/p' "$GW_STATE" | head -1)"
        if [[ "$gw" == running ]]; then
            echo "  $C_OK Hermes 게이트웨이 running (Telegram/cron 전송 가능)"
        else
            echo "  $C_WARN Hermes 게이트웨이 ${gw:-unknown} — Telegram/cron 전송 불가 (hermes gateway restart)"
        fi
    else
        echo "  $C_WARN Hermes 게이트웨이 상태 파일 없음 — 미설치/미실행"
    fi
    if [[ -f "$HOME/.hermes/.env" ]] && grep -qE '^[A-Za-z0-9_]*API_KEY=.+' "$HOME/.hermes/.env"; then
        echo "  $C_OK Hermes 추론 키 설정됨"
    else
        echo "  · Hermes 추론 키 미설정 — 비서 두뇌는 Macsist 자체 LLM 사용(무관)"
    fi

    echo
    if [[ "$fails" == 0 ]]; then
        echo "모든 핵심 점검 통과 ✨"
    else
        echo "핵심 문제 ${fails}건 — 위의 힌트를 따라 해결하세요."
        return 1
    fi
}

cmd_update() {
    echo "· git pull ($REPO_ROOT)"
    git -C "$REPO_ROOT" pull --ff-only || return 1
    echo "· 앱 재배포"
    bash "$REPO_ROOT/app/deploy.sh" || return 1
    if [[ -f "$SERVER_PLIST" ]]; then
        echo "· 서버 재배포"
        bash "$REPO_ROOT/server/deploy.sh" || return 1
    else
        echo "· 서버: 설치되지 않음 — 건너뜀"
    fi
    echo "완료. macsist status 로 확인하세요."
}

usage() { sed -n '4,12p' "$SELF" | sed 's/^# \{0,3\}//'; }

case "${1:-__default__}" in
    __default__) cmd_start ""; echo; cmd_status ;;
    start)   shift; cmd_start "${1:-}" ;;
    stop)    shift; cmd_stop "${1:-}" ;;
    restart) shift; cmd_restart "${1:-}" ;;
    status)  cmd_status ;;
    logs)    shift; cmd_logs "$@" ;;
    settings) post_notification "com.macsist.showSettings" ;;
    history)  post_notification "com.macsist.showHistory" ;;
    tasks)   cmd_tasks ;;
    doctor)  cmd_doctor ;;
    update)  cmd_update ;;
    help|-h|--help) usage ;;
    *) echo "알 수 없는 명령: $1"; usage; exit 2 ;;
esac
